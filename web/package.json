    "react-i18next": "^14.1.3",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.4",
